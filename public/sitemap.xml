// pages/sitemap.xml.js

import { getGames } from "../lib/api";

const SITE_URL = "https://casualbrowsergames.com";

function generateSiteMap(games) {
  // ✅ Static SEO pages
  const staticPages = [
    "/",
    "/about",
    "/privacy",
    "/terms",
    "/faq",
    "/contact",
  ];

  const staticUrls = staticPages
    .map((path) => `
      <url>
        <loc>${SITE_URL}${path}</loc>
        <priority>0.8</priority>
      </url>
    `)
    .join("");

  // ✅ Game pages
  const gameUrls = games
    .map((game) => `
      <url>
        <loc>${SITE_URL}/game/${game.slug}</loc>
        <lastmod>${new Date().toISOString()}</lastmod>
        <priority>0.9</priority>
      </url>
    `)
    .join("");

  return `<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  ${staticUrls}
  ${gameUrls}
</urlset>`;
}

export async function getServerSideProps({ res }) {
  try {
    const games = await getGames(); // fetch all games

    const sitemap = generateSiteMap(games);

    res.setHeader("Content-Type", "text/xml");
    res.write(sitemap);
    res.end();
  } catch (error) {
    console.error("Sitemap generation error:", error);
  }

  return { props: {} };
}

export default function SiteMap() {
  return null;
}
